<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MauiBootstrapTheme.Sample.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:MauiBootstrapTheme.Sample"
    xmlns:pages="clr-namespace:MauiBootstrapTheme.Sample.Pages"
    Shell.FlyoutBehavior="Flyout"
    FlyoutBackgroundColor="{DynamicResource Background}"
    Title="Bootstrap Theme">

    <Shell.FlyoutHeader>
        <Grid HeightRequest="56" Padding="16,0"
              BackgroundColor="{DynamicResource Primary}">
            <Label Text="Bootstrap Theme"
                   TextColor="{DynamicResource OnPrimary}"
                   FontSize="18" FontAttributes="Bold"
                   VerticalOptions="Center"/>
        </Grid>
    </Shell.FlyoutHeader>

    <Shell.ItemTemplate>
        <DataTemplate>
            <Grid Padding="16,12" ColumnDefinitions="Auto,*">
                <Image Source="{Binding FlyoutIcon}"
                       HeightRequest="20" WidthRequest="20"
                       Grid.Column="0" Margin="0,0,12,0"/>
                <Label Text="{Binding Title}"
                       TextColor="{DynamicResource OnBackground}"
                       FontSize="16"
                       VerticalOptions="Center"
                       Grid.Column="1"/>
            </Grid>
        </DataTemplate>
    </Shell.ItemTemplate>

    <FlyoutItem Title="Controls" Route="controls">
        <ShellContent ContentTemplate="{DataTemplate pages:ControlsPage}" />
    </FlyoutItem>
    
    <FlyoutItem Title="Inputs" Route="inputs">
        <ShellContent ContentTemplate="{DataTemplate pages:InputsPage}" />
    </FlyoutItem>
    
    <FlyoutItem Title="Typography" Route="typography">
        <ShellContent ContentTemplate="{DataTemplate pages:TypographyPage}" />
    </FlyoutItem>
    
    <FlyoutItem Title="Cards" Route="cards">
        <ShellContent ContentTemplate="{DataTemplate pages:CardsPage}" />
    </FlyoutItem>
    
    <FlyoutItem Title="Themes" Route="themes">
        <ShellContent ContentTemplate="{DataTemplate pages:ThemesPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Forms" Route="forms">
        <ShellContent ContentTemplate="{DataTemplate pages:FormsPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Visual States" Route="visualstates">
        <ShellContent ContentTemplate="{DataTemplate pages:VisualStatesPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Variants" Route="variants">
        <ShellContent ContentTemplate="{DataTemplate pages:VariantsPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Spacing" Route="spacing">
        <ShellContent ContentTemplate="{DataTemplate pages:SpacingPage}" />
    </FlyoutItem>

</Shell>
